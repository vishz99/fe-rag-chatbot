# Gitignore prevents the following files from being tracked by Git
# Environment
.env

# Data files (too large for Git)
data/raw/*  
data/processed/*
!data/raw/.gitkeep
!data/processed/.gitkeep

# Vector store (too large for Git, regenerated from embed.py)
data/vector_store/

# Documentation (personal, not yet shared)
docs/

# Python
__pycache__/
*.pyc

# Jupyter
.ipynb_checkpoints/

# IDE
.vscode/
